generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Ticker {
  id         Int      @id @default(autoincrement())
  symbol     String   @unique @db.VarChar(16)
  name       String?  @db.VarChar(128)
  notes      String?  @db.Text
  isFavorite Boolean  @default(false) @map("is_favorite")
  createdAt  DateTime @default(now()) @map("created_at")

  tickerWeeks    TickerWeek[]
  analysisEntries AnalysisEntry[]
  earningsEvents  EarningsEvent[]

  @@map("tickers")
}

model Week {
  id            Int      @id @default(autoincrement())
  weekStartDate DateTime @unique @map("week_start_date") @db.Date
  year          Int
  isoWeek       Int      @map("iso_week")

  tickerWeeks TickerWeek[]

  @@map("weeks")
}

model TickerWeek {
  id            Int      @id @default(autoincrement())
  tickerId      Int      @map("ticker_id")
  weekId        Int      @map("week_id")
  priceRangeLow  Decimal? @map("price_range_low") @db.Decimal(12, 4)
  priceRangeHigh Decimal? @map("price_range_high") @db.Decimal(12, 4)
  headerNotes   String?  @map("header_notes") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  ticker          Ticker           @relation(fields: [tickerId], references: [id], onDelete: Cascade)
  week            Week             @relation(fields: [weekId], references: [id], onDelete: Cascade)
  weeklyChecklist WeeklyChecklist?
  dailyMetrics    DailyMetric[]
  trades          Trade[]
  analysisEntries AnalysisEntry[]

  @@unique([tickerId, weekId])
  @@index([tickerId])
  @@index([weekId])
  @@map("ticker_weeks")
}

model WeeklyChecklist {
  tickerWeekId Int @id @map("ticker_week_id")

  fedMet      Boolean? @map("fed_met")
  fedNote     String?  @map("fed_note") @db.VarChar(255)

  earningsMet         Boolean?  @map("earnings_met")
  earningsNote        String?   @map("earnings_note") @db.VarChar(255)
  nextEarningsDate    DateTime? @map("next_earnings_date") @db.Date

  bollingerMet          Boolean?           @map("bollinger_met")
  bollingerTimeframe    BollingerTimeframe? @map("bollinger_timeframe")
  bollingerMidpointNote String?            @map("bollinger_midpoint_note") @db.Text

  maMet         Boolean? @map("ma_met")
  maTimeframes  String?  @map("ma_timeframes") @db.VarChar(64)

  trendBreakMet  Boolean? @map("trend_break_met")
  trendBreakNote String?  @map("trend_break_note") @db.Text

  gapUpMet   Boolean? @map("gap_up_met")
  gapDownMet Boolean? @map("gap_down_met")
  gapNote    String?  @map("gap_note") @db.Text

  bidAskMet Boolean?  @map("bid_ask_met")
  bid       Decimal?  @db.Decimal(12, 4)
  ask       Decimal?  @db.Decimal(12, 4)

  tickerWeek TickerWeek @relation(fields: [tickerWeekId], references: [id], onDelete: Cascade)

  @@map("weekly_checklist")
}

enum BollingerTimeframe {
  M15  @map("15m")
  H1   @map("1h")
  D1   @map("1d")
}

model DailyMetric {
  id           Int      @id @default(autoincrement())
  tickerWeekId Int      @map("ticker_week_id")
  tradeDate    DateTime @map("trade_date") @db.Date
  dayOfWeek    Int      @map("day_of_week")
  distance     Decimal? @db.Decimal(12, 4)
  spotPrice    Decimal? @map("spot_price") @db.Decimal(12, 4)
  strikePrice  Decimal? @map("strike_price") @db.Decimal(12, 4)

  tickerWeek TickerWeek @relation(fields: [tickerWeekId], references: [id], onDelete: Cascade)

  @@unique([tickerWeekId, tradeDate])
  @@map("daily_metrics")
}

model Trade {
  id               Int       @id @default(autoincrement())
  tickerWeekId     Int       @map("ticker_week_id")
  slot             Int       @default(1)
  expirationDate   DateTime? @map("expiration_date") @db.Date
  optionType       String?   @map("option_type") @db.VarChar(10)
  tradeDate        DateTime? @map("trade_date") @db.Date
  tradeTime        DateTime? @map("trade_time") @db.Time(0)
  contracts        Int?
  tradePrice       Decimal?  @map("trade_price") @db.Decimal(12, 4)
  profitabilityUsd Decimal?  @map("profitability_usd") @db.Decimal(12, 2)
  planPercent      Decimal?  @map("plan_percent") @db.Decimal(5, 2)
  createdAt        DateTime  @default(now()) @map("created_at")

  tickerWeek TickerWeek @relation(fields: [tickerWeekId], references: [id], onDelete: Cascade)

  @@index([tickerWeekId])
  @@map("trades")
}

enum AnalysisType {
  NOTE
  PREDICTION
  MISTAKE
}

model AnalysisEntry {
  id           Int          @id @default(autoincrement())
  tickerId     Int          @map("ticker_id")
  tickerWeekId Int?         @map("ticker_week_id")
  entryDate    DateTime     @map("entry_date") @db.Date
  entryAt      DateTime     @default(now()) @map("entry_at")
  type         AnalysisType
  body         String       @db.Text

  ticker     Ticker      @relation(fields: [tickerId], references: [id], onDelete: Cascade)
  tickerWeek TickerWeek? @relation(fields: [tickerWeekId], references: [id], onDelete: SetNull)

  @@index([tickerId, entryDate, entryAt])
  @@map("analysis_entries")
}

enum EarningsPlanStatus {
  DRAFT
  ACTIVE
  DONE
}

model EarningsEvent {
  id           Int       @id @default(autoincrement())
  tickerId     Int       @map("ticker_id")
  earningsDate DateTime  @map("earnings_date") @db.Date
  fiscalPeriod String?   @map("fiscal_period") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at")

  ticker  Ticker          @relation(fields: [tickerId], references: [id], onDelete: Cascade)
  plans   EarningsPlan[]
  outcomes EarningsOutcome[]

  @@index([tickerId, earningsDate])
  @@map("earnings_events")
}

model EarningsPlan {
  id              Int                @id @default(autoincrement())
  earningsEventId Int                @map("earnings_event_id")
  planText        String?            @map("plan_text") @db.Text
  status          EarningsPlanStatus @default(DRAFT)

  earningsEvent EarningsEvent @relation(fields: [earningsEventId], references: [id], onDelete: Cascade)

  @@map("earnings_plans")
}

model EarningsOutcome {
  id              Int      @id @default(autoincrement())
  earningsEventId Int      @map("earnings_event_id")
  actualEps       String?  @map("actual_eps") @db.VarChar(32)
  reactionNote    String?  @map("reaction_note") @db.Text
  followedPlan    Boolean? @map("followed_plan")

  earningsEvent EarningsEvent @relation(fields: [earningsEventId], references: [id], onDelete: Cascade)

  @@map("earnings_outcomes")
}

model FedMeeting {
  id          Int      @id @default(autoincrement())
  meetingDate DateTime @unique @map("meeting_date") @db.Date
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("fed_meetings")
}

model NoteTypeConfig {
  id        Int     @id @default(autoincrement())
  code      String  @unique @db.VarChar(32)
  label     String  @db.VarChar(64)
  hint      String? @db.VarChar(255)
  sortOrder Int     @default(0) @map("sort_order")
  active    Boolean @default(true)

  @@map("note_type_configs")
}

model Strategy {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(255)
  bestFor      String?  @map("best_for") @db.Text
  tendency     String?  @db.VarChar(64)
  /// Absolute path to strategy markdown on disk (STRATEGIES_MD_DIR)
  markdownPath String?  @map("markdown_path") @db.VarChar(512)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("strategies")
}

enum InvestmentPlanMode {
  P35 @map("35")
  P10 @map("10")
}

model InvestmentPlanConfig {
  id                 Int      @id @default(1)
  dailyInvestPercent Decimal  @default(10) @map("daily_invest_percent") @db.Decimal(5, 2)
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("investment_plan_config")
}

/// Starting capital — set once per mode (35%/10%) and real/practice track.
model InvestmentPlanTrackInitial {
  mode           InvestmentPlanMode
  isPractice     Boolean            @map("is_practice")
  initialCapital Decimal            @map("initial_capital") @db.Decimal(14, 2)
  setAt          DateTime           @default(now()) @map("set_at")

  @@unique([mode, isPractice])
  @@map("investment_plan_track_initial")
}

model InvestmentPlanEntry {
  id           Int                @id @default(autoincrement())
  mode         InvestmentPlanMode
  entryDate    DateTime           @map("entry_date") @db.Date
  yearMonth    String             @map("year_month") @db.VarChar(7)
  weekOfMonth  Int                @map("week_of_month")
  ticker       String?            @db.VarChar(16)
  isPractice   Boolean            @default(false) @map("is_practice")
  investAmount Decimal            @map("invest_amount") @db.Decimal(14, 2)
  rentabilidad Decimal            @db.Decimal(14, 2)
  capital      Decimal            @db.Decimal(14, 2)
  createdAt    DateTime           @default(now()) @map("created_at")

  @@index([mode, yearMonth])
  @@index([mode, entryDate])
  @@index([mode, isPractice])
  @@map("investment_plan_entries")
}
